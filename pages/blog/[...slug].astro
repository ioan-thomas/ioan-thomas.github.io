---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const fmt = (d: Date) =>
  d.toLocaleDateString('en-GB', { year: 'numeric', month: 'long', day: 'numeric' });
---

<Base title={post.data.title} description={post.data.description}>
  <article class="post">
    <div class="meta">
      <span>Published {fmt(post.data.pubDate)}</span>
      {post.data.updatedDate && <span>Updated {fmt(post.data.updatedDate)}</span>}
    </div>
    <h1>{post.data.title}</h1>
    {
      post.data.tags.length > 0 && (
        <ul class="chips">
          {post.data.tags.map((t) => <li class="chip">#{t}</li>)}
        </ul>
      )
    }
    <hr />
    <div class="prose">
      <Content />
    </div>
  </article>

  <script>
    // Let wide tables scroll instead of breaking the layout
    document.querySelectorAll('article.post .prose table').forEach((table) => {
      if (table.parentElement?.classList.contains('table-scroll')) return;
      const scroller = document.createElement('div');
      scroller.className = 'table-scroll';
      table.parentNode?.insertBefore(scroller, table);
      scroller.append(table);
    });

    // Wrap each code block in a macOS-style window with a copy button
    document.querySelectorAll('article.post .prose pre').forEach((pre) => {
      if (pre.closest('.code-frame')) return;
      const frame = document.createElement('div');
      frame.className = 'code-frame';

      const bar = document.createElement('div');
      bar.className = 'code-bar';

      const dots = document.createElement('div');
      dots.className = 'code-dots';
      dots.innerHTML = '<span></span><span></span><span></span>';

      const lang = document.createElement('span');
      lang.className = 'code-lang';
      lang.textContent = pre.dataset.language && pre.dataset.language !== 'plaintext'
        ? pre.dataset.language
        : 'shell';

      const copy = document.createElement('button');
      copy.className = 'code-copy';
      copy.type = 'button';
      copy.textContent = 'copy';
      copy.addEventListener('click', async () => {
        try {
          await navigator.clipboard.writeText(pre.innerText);
        } catch {
          const ta = document.createElement('textarea');
          ta.value = pre.innerText;
          document.body.append(ta);
          ta.select();
          document.execCommand('copy');
          ta.remove();
        }
        copy.textContent = 'copied';
        copy.classList.add('done');
        setTimeout(() => {
          copy.textContent = 'copy';
          copy.classList.remove('done');
        }, 1600);
      });

      bar.append(dots, lang, copy);
      pre.parentNode?.insertBefore(frame, pre);
      frame.append(bar, pre);
    });
  </script>
</Base>
