---
import Base from '../layouts/Base.astro';
import { SITE, CERTS, LINKS } from '../consts';
---

<Base title="About" description={`About ${SITE.author}`}>
  <section class="hero">
    <p class="eyebrow">Profile</p>
    <h1>About</h1>
    <p class="lede">
      I'm a penetration tester based in the {SITE.location}, working across internal
      infrastructure, Active Directory and cloud. I hold {CERTS.filter((c) => c.status === 'held')
        .map((c) => c.name)
        .join(' and ')}, with a particular interest in adversary
      simulation — tradecraft, OPSEC and detection-aware testing.
    </p>
    <p class="lede">
      This site is where I publish lab write-ups, methodology notes and the occasional career
      post. Everything here is either from a lab environment or sanitised and shared with
      permission. Views are my own.
    </p>
    {LINKS.length > 0 && <p class="lede">
      Get in touch:
      {LINKS.map((l, i) => (
        <>
          <a href={l.url} rel="me noopener" style="color: var(--crimson);">{l.label}</a>
          {i < LINKS.length - 1 && ' · '}
        </>
      ))}
    </p>}
  </section>
</Base>
