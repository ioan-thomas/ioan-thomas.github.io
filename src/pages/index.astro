---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { SITE, CERTS, FOCUS_AREAS, PROJECTS } from '../consts';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const allPosts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const posts = allPosts.slice(0, 3);
const hasMorePosts = allPosts.length > 3;

const heldCerts = CERTS.filter((c) => c.status === 'held').map((c) => c.name);
const eyebrow = ['Offensive security', SITE.location, heldCerts.join(' / ')]
  .filter(Boolean)
  .join(' · ');

// Split headline into plain/redacted segments: [word] => redacted reveal
const segments = (SITE.headline ?? '').split(/(\[[^\]]+\])/).filter(Boolean).map((part) =>
  part.startsWith('[')
    ? { text: part.slice(1, -1), redact: true }
    : { text: part, redact: false }
);

const fmt = (d: Date) =>
  d.toLocaleDateString('en-GB', { year: 'numeric', month: 'short', day: '2-digit' });
---

<Base>
  <section class="hero hero-marked">
    <canvas id="hero-graph" aria-hidden="true"></canvas>
    <div class="hero-content">
    {eyebrow && <p class="eyebrow">{eyebrow}</p>}
    {
      segments.length > 0 && (
        <h1>
          {segments.map((seg, i) =>
            seg.redact ? (
              <span class="redact" style={`--delay: ${0.5 + i * 0.35}s`}>{seg.text}</span>
            ) : (
              seg.text
            )
          )}
        </h1>
      )
    }
    {SITE.description && <p class="lede">{SITE.description}</p>}
    {
      FOCUS_AREAS.length > 0 && (
        <ul class="chips">
          {FOCUS_AREAS.map((f) => <li class="chip">{f}</li>)}
        </ul>
      )
    }
    </div>
  </section>

  {
    allPosts.length > 0 && (
      <section class="block">
        <div class="block-head">
          <h2>Latest posts</h2>
          {hasMorePosts && <a href={`${base}/blog/`}>all posts →</a>}
        </div>
        <ul class="posts">
          {posts.map((post) => (
            <li>
              <a href={`${base}/blog/${post.id}/`}>
                <time datetime={post.data.pubDate.toISOString()}>{fmt(post.data.pubDate)}</time>
                <span>
                  <span class="t">{post.data.title}</span>
                  {post.data.description && <span class="d">{post.data.description}</span>}
                </span>
              </a>
            </li>
          ))}
        </ul>
      </section>
    )
  }

  {
    CERTS.length > 0 && (
      <section class="block">
        <div class="block-head">
          <h2>Certifications</h2>
        </div>
        <table class="certs">
          <thead>
            <tr>
              <th>Cert</th>
              <th>Issuer</th>
              <th>Year</th>
              <th>Status</th>
            </tr>
          </thead>
          <tbody>
            {CERTS.map((c) => (
              <tr>
                <td>
                  <strong>{c.name}</strong>
                </td>
                <td>{c.org}</td>
                <td>{c.year}</td>
                <td>
                  <span class={`badge ${c.status}`}>{c.status}</span>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </section>
    )
  }

  {
    PROJECTS.length > 0 && (
      <section class="block">
        <div class="block-head">
          <h2>Projects</h2>
        </div>
        {PROJECTS.map((p) => (
          <div class="proj">
            <h3>{p.url ? <a href={p.url} rel="noopener">{p.name}</a> : p.name}</h3>
            {p.description && <p>{p.description}</p>}
            {p.tags?.length > 0 && (
              <ul class="chips">
                {p.tags.map((t) => <li class="chip">{t}</li>)}
              </ul>
            )}
          </div>
        ))}
      </section>
    )
  }

  <script>
    import * as THREE from 'three';
    import { gsap } from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';

    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    /* ── GSAP: hero entrance + scroll reveals ─────────── */
    if (!reduced) {
      gsap.registerPlugin(ScrollTrigger);

      gsap.from('.hero-content > *', {
        y: 18,
        autoAlpha: 0,
        duration: 0.7,
        ease: 'power2.out',
        stagger: 0.12,
        delay: 0.15,
        clearProps: 'all',
      });

      gsap.utils.toArray('section.block').forEach((block) => {
        gsap.from(block as Element, {
          y: 26,
          autoAlpha: 0,
          duration: 0.65,
          ease: 'power2.out',
          clearProps: 'all',
          scrollTrigger: { trigger: block as Element, start: 'top 88%', once: true },
        });
      });
    }

    /* ── Three.js: sparse attack-graph behind the hero ── */
    const canvas = document.getElementById('hero-graph') as HTMLCanvasElement | null;
    if (canvas) {
      const hero = canvas.parentElement!;
      const renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: true });
      renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));

      const scene = new THREE.Scene();
      const camera = new THREE.PerspectiveCamera(55, 1, 0.1, 100);
      camera.position.z = 11;

      // Nodes scattered in a flat-ish slab
      const COUNT = 64;
      const positions = new Float32Array(COUNT * 3);
      const colors = new Float32Array(COUNT * 3);
      const brass = new THREE.Color('#c2a45c');
      const crimson = new THREE.Color('#d4555c');
      const grey = new THREE.Color('#7d8694');
      for (let i = 0; i < COUNT; i++) {
        positions[i * 3] = (Math.random() - 0.5) * 22;
        positions[i * 3 + 1] = (Math.random() - 0.5) * 10;
        positions[i * 3 + 2] = (Math.random() - 0.5) * 6;
        // mostly grey nodes, a few brass, rare crimson — like marked hosts on a graph
        const r = Math.random();
        const c = r > 0.93 ? crimson : r > 0.74 ? brass : grey;
        colors[i * 3] = c.r; colors[i * 3 + 1] = c.g; colors[i * 3 + 2] = c.b;
      }
      const pGeo = new THREE.BufferGeometry();
      pGeo.setAttribute('position', new THREE.BufferAttribute(positions, 3));
      pGeo.setAttribute('color', new THREE.BufferAttribute(colors, 3));
      const points = new THREE.Points(
        pGeo,
        new THREE.PointsMaterial({ size: 0.09, vertexColors: true, transparent: true, opacity: 0.85 })
      );

      // Edges between nearby nodes — computed once, kept faint
      const edges: number[] = [];
      for (let i = 0; i < COUNT; i++) {
        for (let j = i + 1; j < COUNT; j++) {
          const dx = positions[i * 3] - positions[j * 3];
          const dy = positions[i * 3 + 1] - positions[j * 3 + 1];
          const dz = positions[i * 3 + 2] - positions[j * 3 + 2];
          if (dx * dx + dy * dy + dz * dz < 11) {
            edges.push(
              positions[i * 3], positions[i * 3 + 1], positions[i * 3 + 2],
              positions[j * 3], positions[j * 3 + 1], positions[j * 3 + 2]
            );
          }
        }
      }
      const lGeo = new THREE.BufferGeometry();
      lGeo.setAttribute('position', new THREE.BufferAttribute(new Float32Array(edges), 3));
      const lines = new THREE.LineSegments(
        lGeo,
        new THREE.LineBasicMaterial({ color: 0x7d8694, transparent: true, opacity: 0.14 })
      );

      const group = new THREE.Group();
      group.add(points, lines);
      scene.add(group);

      const resize = () => {
        const { clientWidth: w, clientHeight: h } = hero;
        renderer.setSize(w, h, false);
        camera.aspect = w / h;
        camera.updateProjectionMatrix();
      };
      resize();
      window.addEventListener('resize', resize);

      if (reduced) {
        renderer.render(scene, camera); // single static frame
      } else {
        let mx = 0, my = 0, tx = 0, ty = 0;
        window.addEventListener('pointermove', (e) => {
          tx = (e.clientX / window.innerWidth - 0.5) * 0.25;
          ty = (e.clientY / window.innerHeight - 0.5) * 0.15;
        });

        let visible = true;
        new IntersectionObserver(([e]) => (visible = e.isIntersecting)).observe(hero);

        renderer.setAnimationLoop((t) => {
          if (!visible || document.hidden) return;
          group.rotation.y = t * 0.000045 + (mx += (tx - mx) * 0.04);
          group.rotation.x = (my += (ty - my) * 0.04);
          renderer.render(scene, camera);
        });
      }
    }
  </script>
</Base>
